# ===== BUDGET CONTROLLER — CẤU HÌNH =====
# Copy thành ".env" và điền của bạn. KHÔNG chia sẻ .env.

COMPANY_NAME=Công ty của tôi

# Ngân sách tháng theo phòng ban: "Tên phòng:số tiền" cách nhau bởi dấu phẩy
NGAN_SACH=Marketing:5000000,Nhân sự:15000000,Vận hành:8000000
# Cảnh báo vàng khi đã chi >= bao nhiêu % ngân sách
WARN_PERCENT=80

# --- Nguồn dữ liệu (giống CFO) ---
SOURCE=gsheet
GOOGLE_SHEET_CSV_URL=
# Tên cột trong sheet (đổi nếu khác)
COL_DATE=Ngày
COL_DEPT=Phòng ban
COL_TYPE=Loại
COL_AMOUNT=Số tiền

# --- Gửi Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- AI: mặc định dùng GÓI Claude Code, không cần điền gì ---
# CLAUDE_BIN=/Users/ban/.local/bin/claude
# ANTHROPIC_API_KEY=
