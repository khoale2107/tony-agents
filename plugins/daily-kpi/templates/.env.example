# ===== KPI hàng ngày từng nhân viên — CẤU HÌNH =====
TEAM_NAME=Đội Sales Tony

# File dữ liệu KPI (mặc định kpi.csv trong cùng thư mục).
# Chưa có file thật thì agent tự dùng kpi_example.csv để chạy thử.
KPI_FILE=kpi.csv

# Tên cột trong file CSV (đổi cho khớp file của bạn)
COL_NAME=Nhân viên
COL_TARGET=Chỉ tiêu
COL_ACTUAL=Thực đạt

# Telegram (để trống nếu chỉ chạy --dry-run)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== AI: mặc định dùng GÓI Claude Code (không cần API key) =====
# Nếu máy không tự tìm thấy lệnh claude, điền đường dẫn:
# CLAUDE_BIN=/Users/ban/.local/bin/claude
# Chỉ điền nếu buộc phải dùng API key thay cho gói:
# ANTHROPIC_API_KEY=
