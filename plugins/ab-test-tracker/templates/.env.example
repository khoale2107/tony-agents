# ===== A/B TEST TRACKER — CẤU HÌNH =====
# Copy thành ".env" và điền của bạn. KHÔNG chia sẻ .env, KHÔNG commit lên git.

CAMPAIGN_NAME=Chiến dịch cưới mùa thu

# Chọn winner theo chỉ số nào: cvr (chuyển đổi/click) | ctr (click/hiển thị) | conv_rate (chuyển đổi/hiển thị)
WINNER_METRIC=cvr
# Bỏ qua biến thể có hiển thị dưới mức này khi chọn winner (0 = không lọc)
MIN_IMPRESSION=0

# --- Dữ liệu ---
# Đặt file thật tên "ab.csv" cạnh ab_tracker.py. Chưa có thì tự dùng ab_example.csv.
# Tên cột (đổi nếu file của bạn đặt khác):
COL_GROUP=Nhóm
COL_VARIANT=Biến thể
COL_IMPRESSION=Hiển thị
COL_CLICK=Click
COL_CONVERSION=Chuyển đổi

# --- Gửi Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

