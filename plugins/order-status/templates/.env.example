# ===== Theo dõi trạng thái đơn theo khâu — CẤU HÌNH =====
COMPANY_NAME=Xưởng Tony

# Tên cột trong orders.csv (đổi cho khớp file của bạn)
COL_CODE=Mã đơn
COL_CUSTOMER=Khách hàng
COL_PRODUCT=Sản phẩm
COL_STAGE=Khâu
COL_ORDER_DATE=Ngày đặt
COL_DUE_DATE=Hạn giao
COL_NOTE=Ghi chú

# Đơn còn <= số ngày này tới hạn -> đánh dấu "cần chú ý" trong tin Telegram
DUE_SOON_DAYS=2

# ----- Telegram (chỉ cần khi chạy thật, không cần cho --dry-run) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- AI: mặc định dùng GÓI Claude Code (không cần API key) -----
# Để trống cả hai dòng dưới nếu máy đã có lệnh `claude` và đã `claude login`.
