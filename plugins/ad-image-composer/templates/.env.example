# ===== BOT GHÉP ẢNH QUẢNG CÁO — CẤU HÌNH =====
# Kích thước canvas vuông (px) cho bản preview
ADS_CANVAS=1080
# Khoảng hở giữa các ô ảnh (px)
ADS_GAP=16
# Ngưỡng cắt viền trắng (0-255, càng nhỏ càng cắt sát)
ADS_WHITE_THRESHOLD=15
# Số ảnh tối đa đưa cho AI xem để chọn
POOL_SIZE=12

# --- AI chọn ảnh: mặc định dùng GÓI Claude Code (đọc ảnh), không cần API key ---
# CLAUDE_BIN=/Users/ban/.local/bin/claude
