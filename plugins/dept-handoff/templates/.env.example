# ===== DEPT HANDOFF — CẤU HÌNH =====
# Copy thành ".env" và điền của bạn. KHÔNG chia sẻ .env, KHÔNG commit.

COMPANY_NAME=Công ty của tôi

# --- Nguồn dữ liệu đơn hàng ---
# File CSV các đơn (cột: Mã đơn,Khách,SĐT,Sản phẩm,Bộ phận,Ghi chú,Cập nhật).
# Bộ phận là 1 trong: SALES, SẢN XUẤT, GIAO.
# Chưa có file thật thì để nguyên, agent tự dùng orders_example.csv để chạy thử.
ORDERS_FILE=orders.csv

# --- Gửi Telegram ---
# Một bot chung, gửi vào 3 nhóm/chat riêng của từng bộ phận.
TELEGRAM_BOT_TOKEN=
# Chat id (nhóm hoặc cá nhân) của từng bộ phận nhận thông báo bàn giao:
CHAT_SALES=
CHAT_SANXUAT=
CHAT_GIAO=

