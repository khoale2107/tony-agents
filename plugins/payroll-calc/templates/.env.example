# ===== PAYROLL CALC — CẤU HÌNH =====
# Copy thành ".env" và điền của bạn. KHÔNG chia sẻ .env, KHÔNG commit .env.

COMPANY_NAME=Công ty của tôi
# Nhãn kỳ lương in trên báo cáo (tùy chọn), ví dụ: Tháng 07/2026 / Tuần 3
PERIOD=Tháng 07/2026

# --- Nguồn dữ liệu ---
# File chấm công theo sản phẩm/ca/show. Cột: Nhân viên, Loại, Số lượng, Đơn giá
# Loại nhận: sản phẩm | ca | show. Chưa có work.csv thì tự dùng work_example.csv.
WORK_FILE=work.csv
# Tên cột (đổi nếu file bạn đặt khác)
COL_NAME=Nhân viên
COL_TYPE=Loại
COL_QTY=Số lượng
COL_PRICE=Đơn giá

# --- Gửi Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- AI: mặc định dùng GÓI Claude Code, không cần điền gì ---
