# ===== Tình báo đối thủ (Competitor Intelligence) — CẤU HÌNH =====
BRAND_NAME=Tony Wedding

# File dữ liệu đối thủ (mặc định competitor.csv trong cùng thư mục).
# Chưa có file thật thì agent tự dùng competitor_example.csv để chạy thử.
COMPETITOR_FILE=competitor.csv

# Tên cột trong file CSV (đổi cho khớp file của bạn)
COL_NAME=Đối thủ
COL_TYPE=Loại
COL_CONTENT=Nội dung
COL_DATE=Ngày

# Telegram (để trống nếu chỉ chạy --dry-run)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== AI: mặc định dùng GÓI Claude Code (không cần API key) =====
# Nếu máy không tự tìm thấy lệnh claude, điền đường dẫn:
# CLAUDE_BIN=/Users/ban/.local/bin/claude
# Chỉ điền nếu buộc phải dùng API key thay cho gói:
# ANTHROPIC_API_KEY=
