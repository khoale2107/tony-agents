# ===== Bot thu báo cáo cuối ngày — CẤU HÌNH =====
COMPANY_NAME=Công ty của tôi

# File báo cáo thô: cột Nhân viên, Phòng, Nội dung báo cáo
# Chưa có file thật thì tự dùng reports_example.csv để chạy thử.
REPORTS_FILE=reports.csv
COL_STAFF=Nhân viên
COL_DEPT=Phòng
COL_CONTENT=Nội dung báo cáo

# Telegram của SẾP (nơi nhận bản tổng hợp)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== AI: mặc định dùng GÓI Claude Code (KHÔNG cần API key) =====
# Nếu máy không tự thấy lệnh claude, trỏ đường dẫn ở đây:
# CLAUDE_BIN=/Users/ban/.local/bin/claude
# Chỉ điền khi buộc phải dùng API thay cho gói:
# ANTHROPIC_API_KEY=
