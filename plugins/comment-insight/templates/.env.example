# ===== COMMENT INSIGHT — CẤU HÌNH =====
COMPANY_NAME=Kênh của tôi

# Ngành của bạn để AI gợi ý chủ đề content cho đúng
NGANH_HANG=chụp ảnh - quay phim cưới

# File gom comment khách: cột Nguồn, Nội dung
# Chưa có file thật thì tự dùng comments_example.csv để chạy thử.
COMMENTS_FILE=comments.csv
COL_SOURCE=Nguồn
COL_CONTENT=Nội dung

# --- Gửi Telegram (để trống nếu chỉ chạy --dry-run) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== AI: mặc định dùng GÓI Claude Code (KHÔNG cần API key) =====
# Nếu máy không tự thấy lệnh claude, trỏ đường dẫn ở đây:
# CLAUDE_BIN=/Users/ban/.local/bin/claude
# Chỉ điền khi buộc phải dùng API thay cho gói:
# ANTHROPIC_API_KEY=
