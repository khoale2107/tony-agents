# ===== CHẤM CÔNG QUA BOT TELEGRAM — CẤU HÌNH =====

# --- Telegram ---
# Tạo bot bằng @BotFather -> /newbot lấy token dán vào đây.
# Nếu cho chấm công trong NHÓM: @BotFather -> /setprivacy -> Disable để bot đọc được tin nhóm.
TELEGRAM_BOT_TOKEN=

# --- Gửi bảng công cuối ngày (lệnh "report" không --dry-run) ---
# Chat/nhóm nhận bảng tổng hợp. Lấy chat_id: nhắn cho bot rồi gọi getUpdates, hoặc dùng @userinfobot.
TELEGRAM_CHAT_ID=

# --- AI nhận xét bảng công (tuỳ chọn) ---
# Đặt 1 để bot nhờ GÓI Claude Code viết 1 câu nhận xét cuối bảng report. Mặc định 0 (tắt) để chạy offline.
AI_SUMMARY=0

# --- AI: mặc định dùng GÓI Claude Code (không cần API key) ---
# CLAUDE_BIN=/Users/ban/.local/bin/claude
# ANTHROPIC_API_KEY=
