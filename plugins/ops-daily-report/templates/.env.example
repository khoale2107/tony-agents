# ===== OPS DAILY REPORT — CẤU HÌNH =====
# Copy thành ".env" và điền của bạn. KHÔNG chia sẻ, KHÔNG commit .env.

COMPANY_NAME=Xưởng của tôi

# --- Nguồn dữ liệu ---
# File đơn hàng thật (đặt cùng thư mục). Chưa có thì tự dùng orders_example.csv.
ORDERS_FILE=orders.csv
# Trình tự các khâu (cách nhau dấu phẩy, khâu cuối = đã xong).
# Để trống dùng mặc định: NHẬN,THIẾT KẾ,SẢN XUẤT,QC,GIAO,XONG
STAGES=

# Tên cột trong file CSV (đổi nếu file bạn khác)
COL_STAGE=Khâu
COL_DEADLINE=Hạn giao
COL_UPDATE=Cập nhật

# Ngưỡng phát hiện tắc
STALE_DAYS=2          # đơn không cập nhật >= số ngày này = ứ đọng
PILEUP_THRESHOLD=3    # 1 khâu tồn >= số đơn này = có dấu hiệu dồn ứ

# --- Gửi Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- AI: mặc định dùng GÓI Claude Code, không cần điền gì ---
# CLAUDE_BIN=/Users/ban/.local/bin/claude
# ANTHROPIC_API_KEY=
