# ===== ADS MANAGER QUA CHAT — CẤU HÌNH =====

# --- Telegram: bot nhận lệnh & trả lời ---
# Tạo bot: nhắn @BotFather -> /newbot lấy token.
# Nếu dùng trong GROUP: /setprivacy -> Disable để bot đọc được tin nhóm.
TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID chỉ cần khi gửi báo cáo chủ động (poll trả lời trong chat gửi lệnh nên không bắt buộc).
# TELEGRAM_CHAT_ID=

# --- AI: mặc định dùng GÓI Claude Code (không cần API key) ---
# Dùng để diễn giải câu nói tự nhiên ("tắt chiến dịch mùa cưới giúp") thành lệnh.
# CLAUDE_BIN=/Users/ban/.local/bin/claude
# ANTHROPIC_API_KEY=

# --- Nền tảng quảng cáo (điền khi áp thật, dùng trong connector.py) ---
# FB_ACCESS_TOKEN=
# FB_AD_ACCOUNT_ID=
