# ===== ORDER SLA — CẤU HÌNH =====
# Copy thành ".env" và điền của bạn. KHÔNG chia sẻ .env.

COMPANY_NAME=Xưởng của tôi

# Coi là "sắp tới hạn" khi còn <= bao nhiêu ngày (0 = chỉ nhắc hôm nay)
SOON_DAYS=1

# --- Nguồn dữ liệu ---
# Đặt file thật tên "orders.csv" cạnh order_sla.py (chưa có thì dùng orders_example.csv).
# Tên cột trong file (đổi nếu file bạn đặt tên khác):
COL_ORDER=Mã đơn
COL_STEP=Khâu
COL_OWNER=Người phụ trách
COL_STATUS=Trạng thái
COL_DUE=Hạn xử lý

# --- Gửi Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

