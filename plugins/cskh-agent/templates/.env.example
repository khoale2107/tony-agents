# Tên doanh nghiệp (hiện trong lời xưng của trợ lý)
COMPANY_NAME=Tony Wedding

# Giọng điệu trả lời khách
TONE=thân thiện, lịch sự, xưng em - gọi anh/chị

# --- Trí tuệ AI ---------------------------------------------
# MẶC ĐỊNH: dùng GÓI Claude Code — KHÔNG cần điền gì (chỉ cần đã 'claude login').
# (Tùy chọn) chỉ đường dẫn nếu không tìm thấy lệnh claude:
# CLAUDE_BIN=/Users/ban/.local/bin/claude
#
# (Tùy chọn) Dùng API key thay vì gói: cài 'pip install anthropic' rồi điền:
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
