# ===== VOUCHER MAKER — CẤU HÌNH =====
# Copy thành ".env" và điền của bạn. KHÔNG chia sẻ .env, KHÔNG commit .env.

# --- Thương hiệu / template nội dung ---
BRAND_NAME=Tony Wedding
# Gợi ý phong cách để AI soạn nội dung đúng chất thương hiệu
TEMPLATE_HINT=sang trọng, ấm áp, ngắn gọn, dùng cho ngành ảnh cưới
# Tiền tố mã voucher (VD: TW -> TWA3K9)
VOUCHER_PREFIX=TW
# Số ngày hiệu lực mặc định nếu yêu cầu không nêu rõ
VALID_DAYS=30
# Hotline in trên voucher (để trống nếu không cần)
HOTLINE=
# Tên file HTML xuất ra
OUTPUT_HTML=voucher.html

# --- AI: mặc định dùng GÓI Claude Code, không cần điền gì ---
# CLAUDE_BIN=/Users/ban/.local/bin/claude
# ANTHROPIC_API_KEY=
