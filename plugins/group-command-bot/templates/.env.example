# ===== BOT LỆNH TRONG GROUP TELEGRAM — CẤU HÌNH =====

# --- Telegram: bot phải nằm trong nhóm và tắt Privacy Mode (BotFather -> /setprivacy -> Disable)
#     để đọc được tin nhắn nhóm. TELEGRAM_CHAT_ID không bắt buộc: bot trả lời ngay chat gửi lệnh.
TELEGRAM_BOT_TOKEN=

# --- Map keyword -> hành động. Mỗi biến CMD_<keyword> = file | tuỳ chọn ---
# Cú pháp tuỳ chọn (ngăn bằng dấu |):
#   filter:Cột=GiáTrị   chỉ lấy dòng có cột chứa giá trị (không phân biệt hoa thường)
#   title:...           tiêu đề hiển thị
#   cols:Cột1,Cột2      chỉ hiện các cột này (mặc định hiện tất cả)
#   lowstock:1          đánh dấu ⚠️ dòng có SoLuong < Nguong
#   ai:1                nhờ GÓI Claude Code diễn đạt tự nhiên thay vì liệt kê thô
# File thật chưa có thì bot tự đọc <ten>_example.csv (orders_example.csv, stock_example.csv).

CMD_donmoi=orders.csv | filter:TrangThai=Mới | title:Đơn mới cần xử lý
CMD_tonkho=stock.csv | lowstock:1 | title:Tồn kho hiện tại

# Ví dụ lệnh dùng AI để tóm tắt tự nhiên:
# CMD_baocao=orders.csv | ai:1 | title:Tổng quan đơn hàng

# --- AI: mặc định dùng GÓI Claude Code (không cần API key) ---
# CLAUDE_BIN=/Users/ban/.local/bin/claude
# ANTHROPIC_API_KEY=
