# ===== Báo cáo Meta/TikTok Ads — CẤU HÌNH =====
BRAND_NAME=Tony Wedding

# File dữ liệu Ads (mặc định ads.csv trong cùng thư mục).
# Chưa có file thật thì agent tự dùng ads_example.csv để chạy thử.
ADS_FILE=ads.csv

# Tên cột trong file CSV (đổi cho khớp file export của bạn)
COL_CHANNEL=Kênh
COL_CAMPAIGN=Chiến dịch
COL_COST=Chi phí
COL_IMPR=Hiển thị
COL_CLICK=Click
COL_LEAD=Lead

# Telegram (để trống nếu chỉ chạy --dry-run)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== AI: mặc định dùng GÓI Claude Code (không cần API key) =====
# Nếu máy không tự tìm thấy lệnh claude, điền đường dẫn:
# CLAUDE_BIN=/Users/ban/.local/bin/claude
# Chỉ điền nếu buộc phải dùng API key thay cho gói:
# ANTHROPIC_API_KEY=
