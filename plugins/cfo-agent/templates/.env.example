# ============================================================
#  CFO AGENT — CẤU HÌNH
#  Copy file này thành ".env" rồi điền giá trị của BẠN.
#  KHÔNG chia sẻ file .env cho người khác (chứa key/token).
# ============================================================

# --- 1. Trí tuệ AI ------------------------------------------
# MẶC ĐỊNH: dùng GÓI Claude Code (Pro/Max) — KHÔNG cần điền gì ở mục này.
# Điều kiện: máy đã cài Claude Code + đã đăng nhập gói (chạy: claude login),
# và máy BẬT vào lúc lịch chạy. Agent tự gọi 'claude -p' qua gói của bạn.
#
# (Tùy chọn) Nếu lịch chạy báo không tìm thấy lệnh 'claude', chỉ đường dẫn:
# CLAUDE_BIN=/Users/ban/.local/bin/claude
#
# (Tùy chọn) Nếu KHÔNG muốn dùng gói mà muốn trả tiền theo lượt qua API:
#   1) cài thư viện:  pip install anthropic
#   2) điền key lấy tại https://console.anthropic.com -> API Keys
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- 2. Nguồn dữ liệu ---------------------------------------
# SOURCE chọn nơi lấy số:
#   gsheet | csv  -> Google Sheet / file CSV (mặc định, dễ nhất)
#   custom        -> ERP / phần mềm riêng, qua file adapter_custom.py
#                    (mở Claude Code nói "dữ liệu tôi ở <ERP>..." để nó viết giúp)
SOURCE=gsheet

# Dùng cho SOURCE=gsheet/csv:
# Trong Google Sheet: File -> Share -> "Anyone with the link" (Viewer)
# Rồi File -> Download -> CSV, hoặc dùng link export dạng:
#   https://docs.google.com/spreadsheets/d/<ID_SHEET>/export?format=csv&gid=<GID_TAB>
GOOGLE_SHEET_CSV_URL=

# Dùng cho SOURCE=custom (ví dụ — Claude sẽ điền theo ERP của bạn):
# ERP_API_TOKEN=
# ODOO_URL=
# ODOO_DB=
# ODOO_USER=
# ODOO_API_KEY=

# Tên các cột trong sheet (đổi nếu sheet của bạn đặt tên khác)
COL_DATE=Ngày
COL_TYPE=Loại
COL_AMOUNT=Số tiền
COL_ITEM=Hạng mục

# Kỳ báo cáo: day (trong ngày) hoặc month (trong tháng)
REPORT_PERIOD=month

# --- 3. Gửi báo cáo qua Telegram ----------------------------
# Tạo bot: nhắn @BotFather trên Telegram -> /newbot -> lấy token
TELEGRAM_BOT_TOKEN=
# Chat ID nơi nhận báo cáo: nhắn @userinfobot để lấy ID của bạn,
# hoặc thêm bot vào group rồi lấy chat_id của group.
TELEGRAM_CHAT_ID=

# --- 4. Hiển thị -------------------------------------------
COMPANY_NAME=Công ty của tôi
